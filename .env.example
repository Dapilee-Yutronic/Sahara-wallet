# Copy this file to `.env` for local development (optional).
# `.env` is gitignored — never commit real secrets.

# --- Local (default): leave DATABASE_URL unset or empty to use SQLite ---
# SQLITE_PATH=global_wallet.db

# --- Optional: point at a dev Postgres instead of SQLite ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/sahara_dev

# Railway sets DATABASE_URL automatically when you add Postgres — do not paste prod URLs here.
